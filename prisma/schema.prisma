generator client {
    provider = "prisma-client"
    output   = "../src/generated/prisma"
}

datasource db {
    provider = "postgresql"
}

enum Priority {
    High
    Medium
    Low
}

enum Status {
    Open
    Closed
}

model User {
    id        String   @id @default(cuid())
    email     String   @unique
    name      String?
    password  String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    tickets Ticket[]
}

model Ticket {
    id          Int      @id @default(autoincrement())
    subject     String
    description String
    priority    Priority
    status      Status   @default(Open)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    userId String
    user   User   @relation(fields: [userId], references: [id])
}
